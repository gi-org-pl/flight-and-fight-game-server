{
  "name": "flight-and-fight-game-server",
  "version": "0.1.0",
  "description": "",
  "author": "gi-org-pl",
  "private": true,
  "license": "proprietary",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "test:functional": "npx cucumber-js",
    "typeorm": "typeorm-ts-node-commonjs -d src/core/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "database:drop": "npm run typeorm -- schema:drop",
    "database:reset": "npm run database:drop && npm run migration:run",
    "database:seed": "ts-node --transpile-only features/_seed/seed.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/microservices": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "pg": "^8.20.0",
    "typeorm": "^1.0.0",
    "ulidx": "^2.4.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.22.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.0.0",
    "axios": "^1.17.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-gherkin": "^3.1.4",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "uuid": "^11.1.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
